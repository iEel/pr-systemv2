SQLSERVER_HOST=sqlserver.internal.example
SQLSERVER_INSTANCE=alpha
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=IT_PR_DMS
SQLSERVER_USER=CHANGE_ME
SQLSERVER_PASSWORD=CHANGE_ME
SQLSERVER_TRUST_CERT=true

# App server port. Change this when the Next.js server should listen on another local port.
# For nginx/PM2 deployment, also update deploy/nginx/it-pr-dms.conf upstream to the same port.
PORT=3000

# Optional fallback only. The app and Prisma config prefer SQLSERVER_* values when they are complete,
# because SQL Server connection strings need special escaping for characters such as ; : / [ ] { }.
# DATABASE_URL="sqlserver://sqlserver.internal.example:1433;database=IT_PR_DMS;user=CHANGE_ME;password=CHANGE_ME;encrypt=true;trustServerCertificate=true;schema=dbo"

# Private-network Carbone rendering service
CARBONE_URL=http://CHANGE_ME
CARBONE_VERSION=5
CARBONE_CONVERTER=L
CARBONE_TIMEOUT_MS=60000

# Auth.js JWT/session encryption secret. Generate a real value for each environment and keep it stable.
# Example generator: openssl rand -base64 32
AUTH_SECRET=

# Required for category-deactivation confirmations when AUTH_SECRET is not used. Generate a distinct long random value.
# Example generator: openssl rand -base64 32
CATEGORY_DEACTIVATION_CONFIRMATION_SECRET=

# Authentication mode: LOCAL, LDAP, or HYBRID
AUTH_MODE=HYBRID

# AD/LDAP Search + Bind. Keep real values in .env only.
LDAP_ENABLED=false
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=CHANGE_ME
LDAP_BASE_DN=
LDAP_USER_FILTER=(sAMAccountName={{username}})
LDAP_ID_ATTRIBUTE=objectGUID
LDAP_DISPLAY_NAME_ATTRIBUTE=displayName
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_TLS_REJECT_UNAUTHORIZED=true
